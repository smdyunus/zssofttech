# Copy to .env.local (local dev). Do not commit .env.local.
#
# Contact form (Next.js /contact):
# The page calls GET /api/contact — if CONTACT_SMTP_USER + CONTACT_SMTP_PASS are set,
# submissions use Nodemailer (POST /api/contact). Otherwise the browser uses FormSubmit.
# No NEXT_PUBLIC flag required for SMTP once server env is set + redeployed.
#
# Optional: NEXT_PUBLIC_FORMSUBMIT_EMAIL — FormSubmit inbox when SMTP is off (default zssofttech@gmail.com)
# Optional: NEXT_PUBLIC_CONTACT_FORCE_FORMSUBMIT=true — always use browser FormSubmit even if SMTP exists
#
# Vercel / Netlify / etc.: add the same keys in the dashboard
# (e.g. Vercel → Project → Settings → Environment Variables) for Production, then Redeploy.
#
# Who receives enquiries: src/lib/contact-mail.ts (CONTACT_RECIPIENT_EMAILS).
#
# SMTP: Google account with 2-Step Verification + App Password:
#   https://myaccount.google.com/apppasswords

CONTACT_SMTP_HOST=smtp.gmail.com
CONTACT_SMTP_PORT=465
CONTACT_SMTP_USER=yunus@zssofttech.com
CONTACT_SMTP_PASS=your-16-char-app-password

# Optional — defaults to "ZS Soft Tech Website <CONTACT_SMTP_USER>"
# CONTACT_FROM=ZS Soft Tech <yunus@zssofttech.com>

# If 465 is blocked, try:
# CONTACT_SMTP_PORT=587
# CONTACT_SMTP_SECURE=false
